[33m[supervise][0m              (6/20) step 2/2 // OK - freeze で保護（ネストも含めて）
[33m[supervise][0m              (6/20) step 2/2 export const initialState: State = Object.freeze({ count: 0, entries: Object.freeze({}) });

[33m[supervise][0m              (6/20) step 2/2 // OK - ファクトリで毎回新しいインスタンスを返す
[33m[supervise][0m              (6/20) step 2/2 export function createInitialState(): State {
[33m[supervise][0m              (6/20) step 2/2   return { count: 0, entries: {} };
[33m[supervise][0m              (6/20) step 2/2 }
[33m[supervise][0m              (6/20) step 2/2 ```

