[35m[coding-review][0m         (2/20) step 3/3   }

[35m[coding-review][0m         (2/20) step 3/3   private reservationsFor(productId: string): Map<string, number> {
[35m[coding-review][0m         (2/20) step 3/3     const reservations = this.reservations.get(productId);
[35m[coding-review][0m         (2/20) step 3/3     if (reservations !== undefined) {
