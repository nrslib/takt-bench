[35m[coding-review][0m         (2/20) step 3/3   append(streamId: string, events: DomainEvent[], expectedVersion: number): void {
[35m[coding-review][0m         (2/20) step 3/3     const current = this.streams.get(streamId) ?? [];
[35m[coding-review][0m         (2/20) step 3/3     if (current.length !== expectedVersion) {
