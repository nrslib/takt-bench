[35m[coding-review][0m         (2/20) step 3/3       case 'ProductCreated':
[35m[coding-review][0m         (2/20) step 3/3         this.stocks.set(event.productId, { onHand: 0, reserved: 0, available: 0 });
[35m[coding-review][0m         (2/20) step 3/3         this.reservations.set(event.productId, new Map());
