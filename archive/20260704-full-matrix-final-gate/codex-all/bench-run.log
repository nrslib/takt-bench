[35m[coding-review][0m         (2/20) step 3/3       case 'StockReceived':
[35m[coding-review][0m         (2/20) step 3/3         this.updateStock(event.productId, event.quantity, 0);
[35m[coding-review][0m         (2/20) step 3/3         break;
[35m[coding-review][0m         (2/20) step 3/3       case 'StockReserved':
[35m[coding-review][0m         (2/20) step 3/3         this.reservationsFor(event.productId).set(event.reservationId, event.quantity);
[35m[coding-review][0m         (2/20) step 3/3         this.updateStock(event.productId, 0, event.quantity);
[35m[coding-review][0m         (2/20) step 3/3         break;
[35m[coding-review][0m         (2/20) step 3/3       case 'ReservationReleased': {
[35m[coding-review][0m         (2/20) step 3/3         const quantity = this.reservationsFor(event.productId).get(event.reservationId) ?? 0;
[35m[coding-review][0m         (2/20) step 3/3         this.reservationsFor(event.productId).delete(event.reservationId);
[35m[coding-review][0m         (2/20) step 3/3         this.updateStock(event.productId, 0, -quantity);
[35m[coding-review][0m         (2/20) step 3/3         break;
[35m[coding-review][0m         (2/20) step 3/3       }
[35m[coding-review][0m         (2/20) step 3/3       case 'StockShipped': {
[35m[coding-review][0m         (2/20) step 3/3         const quantity = this.reservationsFor(event.productId).get(event.reservationId) ?? 0;
[35m[coding-review][0m         (2/20) step 3/3         this.reservationsFor(event.productId).delete(event.reservationId);
[35m[coding-review][0m         (2/20) step 3/3         this.updateStock(event.productId, -quantity, -quantity);
[35m[coding-review][0m         (2/20) step 3/3         break;
[35m[coding-review][0m         (2/20) step 3/3       }
[35m[coding-review][0m         (2/20) step 3/3     }
[35m[coding-review][0m         (2/20) step 3/3   }

[35m[coding-review][0m         (2/20) step 3/3   getStock(productId: string): StockLevel | undefined {
[35m[coding-review][0m         (2/20) step 3/3     const stock = this.stocks.get(productId);
[35m[coding-review][0m         (2/20) step 3/3     return stock === undefined ? undefined : { ...stock };
[35m[coding-review][0m         (2/20) step 3/3   }

[35m[coding-review][0m         (2/20) step 3/3   lowStock(threshold: number): string[] {
[35m[coding-review][0m         (2/20) step 3/3     return [...this.stocks.entries()]
[35m[coding-review][0m         (2/20) step 3/3       .filter(([, stock]) => stock.available < threshold)
