[35m[coding-review][0m         (2/20) step 3/3 export class InMemoryEventStore implements EventStore {
[35m[coding-review][0m         (2/20) step 3/3   private readonly streams = new Map<string, DomainEvent[]>();

[35m[coding-review][0m         (2/20) step 3/3   load(streamId: string): { events: DomainEvent[]; version: number } {
[35m[coding-review][0m         (2/20) step 3/3     const events = this.streams.get(streamId) ?? [];
[35m[coding-review][0m         (2/20) step 3/3     return { events: [...events], version: events.length };
[35m[coding-review][0m         (2/20) step 3/3   }

[35m[coding-review][0m         (2/20) step 3/3   append(streamId: string, events: DomainEvent[], expectedVersion: number): void {
[35m[coding-review][0m         (2/20) step 3/3     const current = this.streams.get(streamId) ?? [];
[35m[coding-review][0m         (2/20) step 3/3     if (current.length !== expectedVersion) {
[35m[coding-review][0m         (2/20) step 3/3       throw new ConcurrencyError('Expected version does not match current version');
[35m[coding-review][0m         (2/20) step 3/3     }

[35m[coding-review][0m         (2/20) step 3/3     this.streams.set(streamId, [...current, ...events]);
[35m[coding-review][0m         (2/20) step 3/3   }
[35m[coding-review][0m         (2/20) step 3/3 }

[35m[coding-review][0m         (2/20) step 3/3 export class CommandHandler {
[35m[coding-review][0m         (2/20) step 3/3   private readonly store: EventStore;

[35m[coding-review][0m         (2/20) step 3/3   constructor(store: EventStore) {
[35m[coding-review][0m         (2/20) step 3/3     this.store = store;
[35m[coding-review][0m         (2/20) step 3/3   }

[35m[coding-review][0m         (2/20) step 3/3   handle(command: Command): DomainEvent[] {
[35m[coding-review][0m         (2/20) step 3/3     const streamId = command.productId;
[35m[coding-review][0m         (2/20) step 3/3     const { events, version } = this.store.load(streamId);
[35m[coding-review][0m         (2/20) step 3/3     const state = events.reduce(evolve, initialState);
[35m[coding-review][0m         (2/20) step 3/3     const newEvents = decide(state, command);
[35m[coding-review][0m         (2/20) step 3/3     this.store.append(streamId, newEvents, version);
[35m[coding-review][0m         (2/20) step 3/3     return newEvents;
[35m[coding-review][0m         (2/20) step 3/3   }
[35m[coding-review][0m         (2/20) step 3/3 }

[35m[coding-review][0m         (2/20) step 3/3 export class StockProjection {
