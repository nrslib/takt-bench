+    return [];
+  }
+
+  const attachmentIndices: number[] = [];
+  for (const attachment of attachments) {
+    const match = attachment.placeholder.match(/\[Image #(\d+)\]/);
+    if (match) {
+      attachmentIndices.push(Number(match[1]));
+    }
+  }
+
+  const uniqueIndices = new Set(attachmentIndices);
+  if (uniqueIndices.size === attachmentIndices.length) {
+    return [...attachments];
+  }
+
+  const updatedAttachments: TaskAttachment[] = [];
+  const nextImageIndex = Math.max(...uniqueIndices) + 1;
+
+  for (let i = 0; i < attachments.length; i++) {
+    const attachment = attachments[i] as TaskAttachment;
+    const placeholder = `[Image #${nextImageIndex + i}]`;
+    const fileName = `image-${nextImageIndex + i}${path.extname(attachment.fileName)}`;
+    updatedAttachments.push({
+      placeholder,
+      tempPath: attachment.tempPath,
+      fileName,
+    });
+  }
+
+  return updatedAttachments;
+}
+
+export function renumberAttachmentsAndContent(
+  attachments: readonly TaskAttachment[],
+  content: string,
+): { attachments: TaskAttachment[]; content: string } {
+  if (attachments.length === 0) {
+    return { attachments: [...attachments], content };
+  }
+
+  const attachmentIndices: { index: number; hasConflict: boolean }[] = [];
+  const firstOccurrence = new Map<number, number>();
+  const uniqueIndices = new Set<number>();
+
+  for (let i = 0; i < attachments.length; i++) {
+    const attachment = attachments[i] as TaskAttachment;
+    const match = attachment.placeholder.match(/\[Image #(\d+)\]/);
+    if (match) {
+      const index = Number(match[1]);
+      attachmentIndices.push({ index, hasConflict: false });
+      uniqueIndices.add(index);
+      if (!firstOccurrence.has(index)) {
+        firstOccurrence.set(index, i);
+      }
+    } else {
+      attachmentIndices.push({ index: -1, hasConflict: false });
+    }
+  }
+
+  if (uniqueIndices.size === attachmentIndices.length) {
+    return { attachments: [...attachments], content };
+  }
+
+  for (let i = 0; i < attachmentIndices.length; i++) {
+    const entry = attachmentIndices[i];
+    if (entry) {
+      const firstIndex = firstOccurrence.get(entry.index);
+      if (firstIndex !== undefined && firstIndex !== i) {
+        entry.hasConflict = true;
+      }
+    }
+  }
+
+  const updatedAttachments: TaskAttachment[] = [];
+  const placeholderReplacements = new Map<string, string>();
+  const nextImageIndex = Math.max(...uniqueIndices) + 1;
+  let nextFreeIndex = nextImageIndex;
+
+  for (let i = 0; i < attachments.length; i++) {
+    const attachment = attachments[i] as TaskAttachment;
+    const entry = attachmentIndices[i];
+    if (entry && entry.hasConflict) {
+      const placeholder = `[Image #${nextFreeIndex}]`;
+      const fileName = `image-${nextFreeIndex}${path.extname(attachment.fileName)}`;
+      placeholderReplacements.set(attachment.placeholder, placeholder);
+      updatedAttachments.push({
+        placeholder,
+        tempPath: attachment.tempPath,
+        fileName,
+      });
+      nextFreeIndex++;
+    } else {
+      updatedAttachments.push(attachment);
+    }
+  }
+
+  const updatedContent = content.replace(/\[Image #\d+\]/g, (match) =>
+    placeholderReplacements.get(match) ?? match);
+
+  return { attachments: updatedAttachments, content: updatedContent };
+}
