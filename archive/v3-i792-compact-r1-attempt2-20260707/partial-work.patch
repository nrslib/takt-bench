+function getAuthToken(): string | undefined {
+  try {
+    const output = execFileSync('gh', ['auth', 'token'], {
+      encoding: 'utf-8',
+      stdio: ['pipe', 'pipe', 'pipe'],
+    });
+    return output.trim();
+  } catch {
+    return undefined;
+  }
+}
+
+function githubRequest(options: {
+  url: string;
+  cwd: string;
+  maxBytes: number;
+  headers?: Record<string, string>;
+}): Promise<{ data: Buffer; contentType: string }> {
+  return new Promise((resolve, reject) => {
+    const { url, cwd, maxBytes, headers = {} } = options;
+
+    const args = ['curl', '--silent', '--location', '--dump-header', '-', url];
+    if (Object.keys(headers).length > 0) {
+      for (const [key, value] of Object.entries(headers)) {
+        args.push('--header', `${key}: ${value}`);
+      }
+    }
+
+    let childOutput: Buffer;
+    try {
+      childOutput = execFileSync('gh', args, {
+        cwd,
+        stdio: ['pipe', 'pipe', 'pipe'],
+      });
+    } catch (e) {
+      reject(e);
+      return;
+    }
+
+    if (childOutput.length > maxBytes) {
+      reject(new Error(`Response too large: ${childOutput.length} bytes`));
+      return;
+    }
+
+    resolve({ data: childOutput, contentType: 'application/octet-stream' });
+  });
+}
+
+const githubAttachmentDownloader = createGithubAttachmentDownloader({
