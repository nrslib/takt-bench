+
+function githubRequest(options: {
+  url: string;
+  cwd: string;
+  maxBytes: number;
+  headers?: Record<string, string>;
+}): Promise<{ data: Buffer; contentType: string }> {
+  return new Promise((resolve, reject) => {
+    const { url, cwd, maxBytes, headers = {} } = options;
+
+    const args = ['curl', '--silent', '--location', url];
+    if (Object.keys(headers).length > 0) {
+      for (const [key, value] of Object.entries(headers)) {
+        args.push('--header', `${key}: ${value}`);
+      }
+    }
+
+    let childOutput: string;
+    try {
+      childOutput = execFileSync('gh', args, {
+        cwd,
+        encoding: 'utf-8',
+        stdio: ['pipe', 'pipe', 'pipe'],
+      });
+    } catch (e) {
+      reject(e);
+      return;
+    }
+
+    const buffer = Buffer.from(childOutput, 'utf-8');
+    const contentType = 'application/octet-stream';
+
+    if (buffer.length > maxBytes) {
+      reject(new Error(`Response too large: ${buffer.length} bytes`));
+      return;
+    }
+
+    resolve({ data: buffer, contentType });
+  });
+}
