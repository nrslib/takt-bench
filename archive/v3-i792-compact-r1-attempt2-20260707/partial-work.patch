+function getAuthToken(): string | undefined {
+  try {
+    const output = execFileSync('gh', ['auth', 'token'], {
+      encoding: 'utf-8',
+      stdio: ['pipe', 'pipe', 'pipe'],
+    });
+    return output.trim();
+  } catch {
+    return undefined;
